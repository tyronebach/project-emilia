{
  "name": "Agent Profile - Rem (Devoted, Expressive)",
  "description": "Tests Rem's personality: high volatility, fast positive response, forgiving",
  "agent_profile": {
    "baseline_valence": 0.3,
    "baseline_arousal": 0.1,
    "emotional_volatility": 1.2,
    "emotional_recovery": 0.12,
    "trust_gain_multiplier": 1.3,
    "trust_loss_multiplier": 0.7,
    "attachment_ceiling": 0.95,
    "trigger_multipliers": {
      "compliment": 1.5,
      "affirmation": 1.4
    }
  },
  "initial_state": {
    "valence": 0.3,
    "arousal": 0.1,
    "trust": 0.5,
    "attachment": 0.3
  },
  "steps": [
    {
      "description": "User compliments Rem (high multiplier)",
      "triggers": [["compliment", 0.8]],
      "assert": [
        {"field": "valence", "min": 0.45, "max": 0.8}
      ]
    },
    {
      "description": "User affirms Rem",
      "triggers": [["affirmation", 0.7]],
      "assert": [
        {"field": "valence", "min": 0.5}
      ]
    },
    {
      "description": "Trust should grow faster than default (1.3x)",
      "assert": [
        {"field": "trust", "min": 0.52}
      ]
    },
    {
      "description": "Minor conflict (Rem is forgiving - 0.7x trust loss)",
      "triggers": [["conflict", 0.6]],
      "assert": [
        {"field": "trust", "min": 0.42}
      ]
    },
    {
      "description": "Quick comfort restores Rem",
      "triggers": [["comfort", 0.8]],
      "assert": [
        {"field": "valence", "min": 0.3}
      ]
    }
  ]
}

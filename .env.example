# Copy this file to .env and adjust values for your machine/environment.
# Do not commit real secrets.

# =========================
# Core auth + providers
# =========================
CLAWDBOT_TOKEN=replace-with-real-token
AUTH_TOKEN=replace-with-strong-auth-token
AUTH_ALLOW_DEV_TOKEN=1

OPENAI_API_KEY=replace-with-real-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
DIRECT_DEFAULT_MODEL=gpt-5-mini

ELEVENLABS_API_KEY=replace-with-real-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# =========================
# Service endpoints
# =========================
STT_SERVICE_URL=http://localhost:8765
CLAWDBOT_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_URL=

# =========================
# Web / CORS
# =========================
ALLOWED_ORIGINS=http://localhost:3000
DEFAULT_TIMEZONE=America/Vancouver

# =========================
# Storage
# =========================
# Path to the SQLite database. Defaults to /data/emilia.db (suitable for Docker).
# Override for local dev: EMILIA_DB_PATH=./emilia.db
EMILIA_DB_PATH=/data/emilia.db

# =========================
# Memory + retrieval
# =========================
MEMORY_AUTORECALL_ENABLED=0
MEMORY_AUTORECALL_SCORE_THRESHOLD=0.86
MEMORY_AUTORECALL_MAX_ITEMS=2
MEMORY_AUTORECALL_MAX_CHARS=420
MEMORY_AUTORECALL_RUNTIME_TRIGGER_ENABLED=0

# Memory auto-capture (structured extractor; disabled by default)
MEMORY_AUTOCAPTURE_ENABLED=0
MEMORY_AUTOCAPTURE_MODEL=gpt-5-mini
MEMORY_AUTOCAPTURE_TIMEOUT_S=8.0
MEMORY_AUTOCAPTURE_MAX_CANDIDATES=4
MEMORY_AUTOCAPTURE_MIN_CONFIDENCE=0.82
MEMORY_AUTOCAPTURE_MAX_ITEMS_PER_DAY=8

# =========================
# Emotion / weather system
# =========================
TRIGGER_CLASSIFIER_ENABLED=1
TRIGGER_CLASSIFIER_CONFIDENCE=0.25
EMOTION_TRIGGER_CALIBRATION_ENABLED=1

# Sarcasm mitigation: corrects GoEmotions misreads on known sarcastic user phrases
SARCASM_MITIGATION_ENABLED=1
SARCASM_POSITIVE_DAMPEN_FACTOR=0.35
SARCASM_RECENT_NEGATIVE_DAMPEN_FACTOR=0.6
SARCASM_RECENT_POSITIVE_THRESHOLD=0.45

EMOTION_SESSION_REANCHOR_MODE=soft
EMOTION_REANCHOR_ALPHA_SHORT_GAP=0.25
EMOTION_REANCHOR_ALPHA_LONG_GAP=0.60
EMOTION_REANCHOR_LONG_GAP_HOURS=24

# =========================
# Dreams / climate system
# =========================
DREAM_CONTEXT_MAX_MESSAGES=60
DREAM_INCLUDE_ROOM_SUMMARY=1
DREAM_INCLUDE_MEMORY_HITS=1
DREAM_MEMORY_HITS_MAX=3
DREAM_LIVED_EXPERIENCE_MAX_CHARS=2400
DREAM_NEGATIVE_EVENT_COOLDOWN_HOURS=12

# =========================
# Embeddings / memory index
# =========================
EMILIA_EMBED_PROVIDER=ollama
EMILIA_EMBED_MODEL=mxbai-embed-large
EMILIA_EMBED_BASE_URL=http://localhost:11434
# GEMINI_API_KEY=replace-when-using-gemini-embeddings

# =========================
# TTS cache
# =========================
TTS_CACHE_ENABLED=1
TTS_CACHE_TTL_SECONDS=604800
TTS_CACHE_MAX_ENTRIES=200

# =========================
# Misc runtime knobs
# =========================
CHAT_HISTORY_LIMIT=20
DIRECT_TOOL_MAX_STEPS=6
COMPACT_THRESHOLD=25
COMPACT_KEEP_RECENT=10
COMPACT_MODEL=gpt-4o-mini
COMPACTION_PERSONA_MODE=dm_only
COMPACTION_TEXTURE_MAX_LINES=6
COMPACTION_OPEN_THREADS_MAX=5

SOUL_SIM_PERSONA_MODEL=gpt-5-mini
SOUL_SIM_JUDGE_MODEL=gpt-5-mini
SOUL_SIM_MAX_TURNS=8

# =========================
# Optional / advanced
# =========================
# Comma-separated agent IDs allowed in Games v2 mode
# GAMES_V2_AGENT_ALLOWLIST=
# Seed database with test data on startup (dev only)
# EMILIA_SEED_DATA=0
